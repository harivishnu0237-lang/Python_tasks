class Student:
    def __init__(self, name, roll_no, marks):
        self.name = name
        self.roll_no = roll_no
        self.marks = marks

    def display(self):
        print("Name:", self.name)
        print("Roll No:", self.roll_no)
        print("Marks:", self.marks)



s1 = Student("Hari", 101, 90)
s2 = Student("Vishnu", 102, 85)


s1.display()
s2.display()
